@page
@model Ravenous.Pages.Groceries.EditModel

@{
    ViewData["Title"] = "Edit Grocery Item";
}

<h1>@ViewData["Title"]</h1>

<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="GroceryList.PkGroceryList" />
            <div class="form-group">
                <label asp-for="GroceryList.FkIngredient" class="control-label"></label>
                <select asp-for="GroceryList.FkIngredient" class="form-control" asp-items="ViewBag.FkIngredient"></select>
                <span asp-validation-for="GroceryList.FkIngredient" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="GroceryList.IngredientAmount" class="control-label"></label>
                <input asp-for="GroceryList.IngredientAmount" class="form-control" />
                <span asp-validation-for="GroceryList.IngredientAmount" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="GroceryList.FkMeasurement" class="control-label"></label>
                <select asp-for="GroceryList.FkMeasurement" class="form-control" asp-items="ViewBag.FkMeasurement"></select>
                <span asp-validation-for="GroceryList.FkMeasurement" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="./Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
