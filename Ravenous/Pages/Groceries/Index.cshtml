@page
@model Ravenous.Pages.Groceries.IndexModel

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-page="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.GroceryList[0].IngredientAmount)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.GroceryList[0].Ingredient)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.GroceryList[0].Measurement)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.GroceryList) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.IngredientAmount)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Ingredient.IngredientName)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Measurement.MeasurementName)
            </td>
            <td>
                <a asp-page="./Edit" asp-route-id="@item.PkGroceryList">Edit</a> |
                <a asp-page="./Details" asp-route-id="@item.PkGroceryList">Details</a> |
                <a asp-page="./Delete" asp-route-id="@item.PkGroceryList">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
