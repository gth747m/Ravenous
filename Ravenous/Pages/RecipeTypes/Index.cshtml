@page
@model Ravenous.Pages.RecipeTypes.IndexModel

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-page="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.RecipeType[0].RecipeTypeName)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.RecipeType) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.RecipeTypeName)
            </td>
            <td>
                <a asp-page="./Edit" asp-route-id="@item.PkRecipeType">Edit</a> |
                <a asp-page="./Details" asp-route-id="@item.PkRecipeType">Details</a> |
                <a asp-page="./Delete" asp-route-id="@item.PkRecipeType">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
