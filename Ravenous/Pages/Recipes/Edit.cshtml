@page
@model Ravenous.Pages.Recipes.EditModel

@{
    ViewData["Title"] = "Edit Recipe";
}

<h1>@ViewData["Title"]</h1>

<hr />
<div class="row">
    <div class="col-md-12">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Recipe.PkRecipe" />
            <div class="row">
                <div class="form-group col-md-6">
                    <label asp-for="Recipe.RecipeName" class="control-label"></label>
                    <input asp-for="Recipe.RecipeName" class="form-control" />
                    <span asp-validation-for="Recipe.RecipeName" class="text-danger"></span>
                </div>
                <div class="form-group col-md-6">
                    <label asp-for="Recipe.FkRecipeType" class="control-label"></label>
                    <select asp-for="Recipe.FkRecipeType" class="form-control" asp-items="ViewBag.FkRecipeType"></select>
                    <span asp-validation-for="Recipe.FkRecipeType" class="text-danger"></span>
                </div>
            </div>
            <div class="row">
                <div class="form-group col-md-6">
                    <label asp-for="Recipe.PrepTime" class="control-label"></label>
                    <input asp-for="Recipe.PrepTime" class="form-control" />
                    <span asp-validation-for="Recipe.PrepTime" class="text-danger"></span>
                </div>
                <div class="form-group col-md-6">
                    <label asp-for="Recipe.CookTime" class="control-label"></label>
                    <input asp-for="Recipe.CookTime" class="form-control" />
                    <span asp-validation-for="Recipe.CookTime" class="text-danger"></span>
                </div>
            </div>
            <div class="form-group">
                <label asp-for="Recipe.Rating" class="control-label"></label>
                <input asp-for="Recipe.Rating" class="form-control" />
                <span asp-validation-for="Recipe.Rating" class="text-danger"></span>
            </div>
            <div class="row">
                <div class="form-group">
                    <div class="table">
                        <table>
                            <tr>
                            @{
                                int cnt = 0;

                                foreach (var tag in Model.TagList)
                                {
                                    if (cnt++ % 3 == 0)
                                    {
                                        @:</tr><tr>
                                    }
                                    @:<td>
                                        <input type="checkbox"
                                               name="selectedTags"
                                               value="@tag.TagName"
                                               @(Html.Raw(tag.Assigned ? "checked=\"checked\"" : "")) />
                                               @tag.TagName
                                    @:</td>
                                }
                                @:</tr>
                            }
                        </table>
                    </div>
                </div>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="./Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
