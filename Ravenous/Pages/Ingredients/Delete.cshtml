@page
@model Ravenous.Pages.Ingredients.DeleteModel

@{
    ViewData["Title"] = "Delete Ingredient";
}

<h1>@ViewData["Title"]</h1>

<h3>Are you sure you want to delete this?</h3>
<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Ingredient.IngredientName)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Ingredient.IngredientName)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Ingredient.IngredientType)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Ingredient.IngredientType.IngredientTypeName)
        </dd>
    </dl>
    
    <form method="post">
        <input type="hidden" asp-for="Ingredient.PkIngredient" />
        <input type="submit" value="Delete" class="btn btn-danger" /> |
        <a asp-page="./Index">Back to List</a>
    </form>
</div>
