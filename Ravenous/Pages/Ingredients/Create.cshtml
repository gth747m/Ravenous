@page
@model Ravenous.Pages.Ingredients.CreateModel

@{
    ViewData["Title"] = "Create Ingredient";
}

<h1>@ViewData["Title"]</h1>

<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Ingredient.IngredientName" class="control-label"></label>
                <input asp-for="Ingredient.IngredientName" class="form-control" />
                <span asp-validation-for="Ingredient.IngredientName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Ingredient.FkIngredientType" class="control-label"></label>
                <select asp-for="Ingredient.FkIngredientType" class ="form-control" asp-items="ViewBag.FkIngredientType"></select>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
