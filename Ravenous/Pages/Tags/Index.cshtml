@page
@model Ravenous.Pages.Tags.IndexModel

@{
    ViewData["Title"] = "Tag Index";
}

<h1>@ViewData["Title"]</h1>

<p>
    <a asp-page="Create">Create New</a>
</p>
<hr />
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Tag[0].TagName)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.Tag) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.TagName)
            </td>
            <td>
                <a asp-page="./Edit" asp-route-id="@item.PkTag">Edit</a> |
                <a asp-page="./Details" asp-route-id="@item.PkTag">Details</a> |
                <a asp-page="./Delete" asp-route-id="@item.PkTag">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
