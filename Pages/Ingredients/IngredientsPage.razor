@page "/ingredients"

<div class="title-row">
  <h3 class="title-heading">Ingredients</h3>
  <button class="btn btn-outline-dark add-btn" @onclick="OnAddIngredientClick">
      <span class="oi oi-plus" aria-hidden="true"></span> New
  </button>
</div>

@if (Ingredients == null)
{
  <h3>Loading...</h3>
}
else
{
  <table class="table table-hover table-striped">
    <thead>
      <tr>
        <th>Name</th>
      </tr>
    </thead>
    <tbody>
      <Virtualize Items="Ingredients" Context="ingredient">
        <tr @onclick=@(_ => OnIngredientClick(ingredient.IngredientId))>
          <td>@ingredient.Name</td>
        </tr>
      </Virtualize>
    </tbody>
  </table>
}