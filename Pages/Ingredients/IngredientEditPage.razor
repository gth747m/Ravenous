@page "/ingredients/edit/{Id:int}"

<div class="title-row">
  <h3 class="title-heading">Edit Ingredient</h3>
  <button class="btn btn-outline-danger" @onclick="OnDelete">
    <span class="oi oi-trash" aria-hidden="true"></span> Delete
  </button>
</div>

@if (Ingredient == null)
{
  <p>Loading...</p>
}
else
{
  <EditForm Model="@Ingredient" OnValidSubmit="@OnValidSumbit">
    <DataAnnotationsValidator />
    <ValidationSummary />
    <div class="form-group">
      <div class="input-group">
        <div class="input-group-prepend">
          <label class="input-group-text">Name</label>
        </div>
        <InputText class="form-control" @bind-Value=Ingredient.Name />
      </div>
    </div>
    <div class="form-group form-btn-group">
      <button type="submit" class="btn btn-primary">Save</button>
      <button type="button" class="btn btn-danger" @onclick="@OnCancel">Cancel</button>
    </div>
  </EditForm>
}
