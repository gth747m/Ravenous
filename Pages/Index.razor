@page "/"
@page "/recipes"

<div class="title-row">
  <h3 class="title-heading">Recipes</h3>
  <button class="btn btn-outline-dark add-btn" @onclick="OnAddRecipeClick">
      <span class="oi oi-plus" aria-hidden="true"></span> New
  </button>
</div>

@if (RecipeList == null)
{
  <h3>Loading...</h3>
}
else
{
  <table class="table table-hover table-striped">
    <thead>
      <tr>
        <th>Name</th>
      </tr>
    </thead>
    <tbody>
      <Virtualize Items="RecipeList" Context="ingredient">
        <tr @onclick=@(_ => OnRecipeClick(ingredient.RecipeId))>
          <td>@ingredient.Name</td>
        </tr>
      </Virtualize>
    </tbody>
  </table>
}
