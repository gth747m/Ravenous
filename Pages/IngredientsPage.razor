@page "/ingredients"

<h3>Ingredients</h3>

@if (Ingredients == null)
{
  <h3>Loading...</h3>
}
else
{
  <table class="table table-hover table-striped">
    <thead>
      <tr>
        <th>Name</th>
      </tr>
    </thead>
    <tbody>
      @foreach (var ingredient in Ingredients)
      {
        <tr>
          <td>@ingredient.Name</td>
        </tr>
      }
    </tbody>
  </table>
}