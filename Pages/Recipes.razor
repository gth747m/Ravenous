@page "/recipes"
@using System;
@using Ravenous.Models.DbModels;
@using Microsoft.EntityFrameworkCore;
@inject RavenousContext context
@inject NavigationManager navManager

<div class="alert alert-danger alert-dismissible fade show" role="alert" hidden="@hideErrorAlert">
    @errorMessage
    <button type="button" @onclick="@(e => OnClickAlertClose())" class="close" data-dismiss="alert" aria-label="close">
        <span aria-hidden="true">&times;</span>
    </button>
</div>


<h1>Recipes</h1>
<div style="padding-bottom: 10px">
    <a type="button" class="btn btn-outline-secondary" href="add_recipe">Add Recipe</a>
</div>
<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th scope="col">Recipe</th>
            <th scope="col">Type</th>
            <th scope="col">Prep Time</th>
            <th scope="col">Cook Time</th>
            <th scope="col">Rating</th>
            <th scope="col"></th>
        </tr>
    </thead>
    <tbody>
        <Virtualize Context="recipe" Items="@recipes">
            <tr @onclick="@(e => OnClickRecipe(recipe.PkRecipe))">
                <td>@recipe.RecipeName</td>
                <td>@recipe.RecipeType.RecipeTypeName</td>
                <td>@recipe.PrepTime.ToString(@"hh\:mm")</td>
                <td>@recipe.CookTime.ToString(@"hh\:mm")</td>
                <td>@recipe.Rating</td>
                <td><button type="button" class="btn btn-outline-dark" @onclick="@(e => OnClickDeleteRecipe(recipe.PkRecipe))">Delete</button></td>
            </tr>
        </Virtualize>
    </tbody>
</table>

@code {
    private bool hideErrorAlert;
    private string errorMessage;
    private string newRecipeName;
    private List<Recipe> recipes;

    private async void GetRecipes()
    {
        hideErrorAlert = true;
        recipes = await context.Recipe
            .Include(r => r.RecipeType)
            .OrderBy(r => r.RecipeName)
            .ToListAsync();
    }
    
    protected override void OnInitialized()
    {
        base.OnInitialized();
        GetRecipes();
    }

    protected void OnClickAlertClose()
    {
        errorMessage = "";
        hideErrorAlert = true;
    }

    protected async void OnClickAddRecipe()
    {
        if (recipes.Where(r => r.RecipeName.Equals(newRecipeName)).Any()) 
        {
            errorMessage = "Error: An recipe type with that name already exists.";
            hideErrorAlert = false;
            return;
        }
        Recipe newRecipe = new Recipe {
            RecipeName = newRecipeName
        };
        try 
        {
            context.Recipe.Add(newRecipe);
            await context.SaveChangesAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            hideErrorAlert = false;
            return;
        }
        newRecipeName = "";
        GetRecipes();
    }

    protected void OnClickRecipe(int pkRecipe)
    {
        // TODO: Route to recipe details
        Console.WriteLine("Clicked on recipe.");
        navManager.NavigateTo("ingredients");
    }
    
    protected async void OnClickDeleteRecipe(int pkRecipe)
    {
        var recipeToRemove = recipes.Where(r => r.PkRecipe == pkRecipe).FirstOrDefault();
        if (recipeToRemove != null)
        {
            context.Recipe.Remove(recipeToRemove);
            await context.SaveChangesAsync();
            GetRecipes();
        }
    }
    
}